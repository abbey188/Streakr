# ─── Streakr environment ──────────────────────────────────────────────
# Copy to .env.local and fill in. Never commit .env.local.

# ─── Database (Neon Postgres) ─────────────────────────────────────────
# Pooled connection string from the Neon dashboard.
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/streakr?sslmode=require"

# ─── Privy (auth — identity only in v1) ───────────────────────────────
# Email OTP + Google/Apple login; auto-creates a Solana embedded wallet used
# as the identity key. From the Privy Dashboard (https://dashboard.privy.io).
# Public, browser-safe.
NEXT_PUBLIC_PRIVY_APP_ID=""
# Solana network for wallet identity. mainnet for the real product.
NEXT_PUBLIC_SOLANA_NETWORK="mainnet"

# ─── TxLINE (live World Cup data — wired later) ───────────────────────
# Server-side only. One developer wallet activates a long-lived token.
TXLINE_API_BASE_URL="https://api.txline.example"
TXLINE_DEVELOPER_WALLET_PRIVATE_KEY=""
TXLINE_API_TOKEN=""

# ─── App ──────────────────────────────────────────────────────────────
# Server-side secret for signing our own session tokens.
SESSION_SECRET=""
# Protects the live-sync cron endpoint (Vercel Cron sends it as a Bearer token).
CRON_SECRET=""
